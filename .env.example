# ============================================
# LAWPAL - COMPLETE ENVIRONMENT SETUP GUIDE
# ============================================
# This file documents all environment variables needed
# Copy and update these values in your respective .env files
# 
# Structure:
# - server/.env (Node.js Express Backend)
# - LawPal-Backend/.env (Python Flask RAG Engine)
# ============================================

# ============================================
# 1. SERVER BACKEND (.env in server/ folder)
# ============================================

# Port where Express server runs
PORT=3007

# Node environment
NODE_ENV=development

# MongoDB Connection String
# For local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/lawpal
# 
# For MongoDB Atlas (Cloud - Recommended):
# 1. Create account at https://www.mongodb.com/cloud/atlas
# 2. Create a cluster and database
# 3. Get connection string and add credentials
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lawpal?retryWrites=true&w=majority

# JWT Secret for authentication tokens
# Generate with: openssl rand -base64 32
# CRITICAL: Use strong, random secret in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345

# Groq API Key for fallback LLM and AI Judge
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-actual-groq-api-key-here

# Groq Model Name (optional, defaults to llama-3.3-70b-versatile)
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# Flask Backend URL (Python RAG Engine)
# Make sure Python backend is running before starting server
FLASK_BACKEND_URL=http://localhost:7860

# ============================================
# 2. PYTHON BACKEND (.env in LawPal-Backend/ folder)
# ============================================

# Flask server port
PORT=7860
FLASK_ENV=development

# Groq API Keys (can be multiple, comma-separated)
# These are used for the RAG pipeline and fallback
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# Groq Model Selection
# Recommended: llama-3.3-70b-versatile
# Other options: llama-2-70b-chat, mixtral-8x7b-32768
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# ChromaDB Path (stores Indian legal documents)
CHROMA_DB_PATH=./chroma_db

# Embedding Model (auto-downloaded on first run)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Redis URL (optional - for chat memory)
# REDIS_URL=redis://localhost:6379/0

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3007,http://localhost:5173,http://localhost:3000

# ============================================
# GETTING API KEYS
# ============================================

# 1. GROQ API KEY
#    Website: https://console.groq.com/keys
#    Step 1: Sign up for free at Groq
#    Step 2: Go to API Keys section
#    Step 3: Create new API key
#    Step 4: Copy and paste into GROQ_API_KEY

# 2. MONGODB URI
#    Website: https://www.mongodb.com/cloud/atlas
#    Step 1: Sign up for free
#    Step 2: Create a cluster
#    Step 3: Add database user with password
#    Step 4: Whitelist your IP address
#    Step 5: Get connection string and replace username:password
#    Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# 3. JWT SECRET
#    Generate with: openssl rand -base64 32
#    Or use: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# ============================================
# DEFAULT VALUES & IMPORTANT NOTES
# ============================================

# Port 3007 - Node.js Backend (Express Server)
# Port 7860 - Python Backend (Flask RAG Engine)
# Port 5173 - Frontend (React + Vite) - if you create frontend later

# RAG System Architecture:
# 1. User sends query via Frontend
# 2. Node.js Server receives request
# 3. Server forwards to Python Flask backend
# 4. Flask uses RAG to search ChromaDB (Indian legal docs)
# 5. Flask queries Groq API for answer generation
# 6. Response streamed back to Node.js and then to Frontend

# AI Judge (MiniCourt):
# 1. User inputs case details
# 2. Server calls /api/simulate-trial endpoint
# 3. Uses Groq API to analyze case
# 4. Returns verdict, arguments, and win probability

# ============================================
# STARTING THE SYSTEM
# ============================================

# Terminal 1 - Python Backend:
# cd LawPal-Backend
# source venv/bin/activate  # On Windows: venv\Scripts\activate
# python app.py             # Runs on port 7860

# Terminal 2 - Node.js Server:
# cd server
# npm install
# node server.js            # Runs on port 3007

# Terminal 3 - Frontend (when ready):
# cd frontend
# npm install
# npm run dev               # Runs on port 5173

# ============================================
# TROUBLESHOOTING
# ============================================

# Issue: Cannot connect to MongoDB
# Solution: 
# 1. Check MongoDB URI in server/.env
# 2. Ensure IP address is whitelisted in MongoDB Atlas
# 3. Verify database user credentials
# 4. Check internet connection

# Issue: Groq API returns 401 error
# Solution:
# 1. Verify GROQ_API_KEY is correct and not expired
# 2. Check that key doesn't have leading/trailing spaces
# 3. Go to https://console.groq.com/keys and create new key if needed

# Issue: Flask backend connection timeout
# Solution:
# 1. Ensure Python backend is running: python LawPal-Backend/app.py
# 2. Check FLASK_BACKEND_URL in server/.env (should be http://localhost:7860)
# 3. Verify port 7860 is not blocked by firewall

# ============================================
