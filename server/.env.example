# ============================================
# LAWPAL SERVER ENVIRONMENT VARIABLES
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3007
NODE_ENV=development

# ============================================
# MONGODB DATABASE
# ============================================
# Local MongoDB (if running locally)
# MONGODB_URI=mongodb://localhost:27017/lawpal

# MongoDB Atlas (Cloud)
# Replace with your actual MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lawpal?retryWrites=true&w=majority

# ============================================
# JWT AUTHENTICATION
# ============================================
# Use a strong, random secret key for production
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345

# ============================================
# GROQ API KEYS (Multiple for fallback/load-balancing)
# ============================================
# Get your API keys from: https://console.groq.com/keys
# Add multiple keys separated by commas for fallback & load balancing
# Format: key1,key2,key3
GROQ_API_KEYS=

# Primary Groq Model (for RAG chatbot & AI Judge)
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# Groq API Base URL
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Alternative/Fallback Models (optional)
# Use if primary model is rate limited
# GROQ_FALLBACK_MODEL=llama-2-70b-chat
# GROQ_JUDGE_MODEL=mixtral-8x7b-32768

# ============================================
# FLASK BACKEND (RAG Engine)
# ============================================
# URL where your Python Flask RAG backend is running
FLASK_BACKEND_URL=http://localhost:7860

# ============================================
# CORS CONFIGURATION (Optional)
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
