# ============================================
# LAWPAL PYTHON BACKEND ENVIRONMENT VARIABLES
# RAG Engine with ChromaDB & Groq Integration
# ============================================

# ============================================
# GROQ API KEYS (Multiple for fallback/load-balancing)
# ============================================
# Get your API keys from: https://console.groq.com/keys
# Add 3+ keys for better fallback & rate limit handling
# Format: key1,key2,key3,key4
GROQ_API_KEYS=your-groq-api-key-1-here,your-groq-api-key-2-here,your-groq-api-key-3-here,your-groq-api-key-4-here

# ============================================
# GROQ MODEL SELECTION
# ============================================
# Primary Model (for RAG chatbot)
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# Fallback Models (if primary is rate limited)
# Available models:
# - llama-2-70b-chat
# - mixtral-8x7b-32768
# GROQ_FALLBACK_MODELS=llama-2-70b-chat,mixtral-8x7b-32768

# Judge-specific Model (for trial simulation)
# GROQ_JUDGE_MODEL=llama-3.3-70b-versatile

# ============================================
# FLASK SERVER CONFIGURATION
# ============================================
PORT=7860
FLASK_ENV=development

# ============================================
# CHROMADB CONFIGURATION
# ============================================
# Path to persistent ChromaDB (contains Indian legal documents)
CHROMA_DB_PATH=./chroma_db

# ============================================
# EMBEDDING MODEL
# ============================================
# Using BAAI/bge-large-en-v1.5 for embedding
# This is automatically downloaded on first run
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ============================================
# REDIS (Optional - for chat memory)
# ============================================
# Only needed if using RedisChatMemory feature
# Format: redis://username:password@localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# ============================================
# LOGGING & DEBUG
# ============================================
LOG_LEVEL=INFO
DEBUG=true

# ============================================
# CORS CONFIGURATION
# ============================================
# Allow requests from Node.js backend
ALLOWED_ORIGINS=http://localhost:3007,http://localhost:5173,http://localhost:3000
